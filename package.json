{
  "name": "@owdproject/theme-paper",
  "version": "0.0.1",
  "description": "Open Web Desktop theme",
  "homepage": "https://github.com/owdproject/theme-paper",
  "license": "MIT",
  "author": {
    "name": "Open Web Desktop Team",
    "url": "https://github.com/owdproject"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "development": "./src/module.ts",
      "import": "./dist/module.mjs",
      "default": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "files": ["dist", "src"],
  "nx": { "name": "theme-paper" },
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "pnpm run dev:prepare && cd playground && pnpm exec nuxt dev",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && cd playground && pnpm exec nuxt prepare",
    "dev:generate": "NUXT_APP_BASE_URL=${NUXT_APP_BASE_URL:-/theme-paper/} nuxt generate playground",
    "validate": "desktop validate ."
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.6",
    "@owdproject/kit-primevue": "workspace:*"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.2",
    "@owdproject/core": "workspace:*",
    "@owdproject/kit-primevue": "workspace:*",
    "nuxt": "^4.4.6",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.3"
  },
  "peerDependencies": {
    "@owdproject/core": "^3.4.0",
    "@owdproject/kit-primevue": "^0.0.1"
  }
}
